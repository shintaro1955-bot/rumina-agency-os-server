# ===== agency-crawler 環境変数 =====
# Google Maps Platform のキー（★Places API (New) を有効化しておくこと）
# rumina_server/.env / solar-savings-simulator の GOOGLE_MAPS_API_KEY (AIza…) をそのまま使えます
GOOGLE_MAPS_API_KEY=your_google_maps_platform_key

# AI(リサーチ/発掘/日報生成)用 — rumina_server/.env の ANTHROPIC_API_KEY を流用可
ANTHROPIC_API_KEY=sk-ant-...

# (任意) Programmable Search Engine を使う場合
# GOOGLE_CSE_KEY=your_custom_search_api_key
# GOOGLE_CSE_ID=your_cse_cx_id

# サーバのポート
PORT=8787
